  {
    "title": "Eurostat: EU imports of energy products decreased again in 2025",
    "link": "https://energy.ec.europa.eu/news/eurostat-eu-imports-energy-products-decreased-again-2025-2026-03-25_en",
    "pubDate": "2026-03-25T15:57:48.000Z",
